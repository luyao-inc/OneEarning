{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/paperclip/*"],
      "@shell/*": ["src/shell/*"],
      "@electron/*": ["electron/*"]
    }
  },
  "include": ["src", "electron/**/*.ts", "electron/**/*.tsx", "vite.config.ts"],
  "exclude": [
    "node_modules",
    "src/paperclip/**/*.test.ts",
    "src/paperclip/**/*.test.tsx",
    "src/paperclip/**/*.spec.ts",
    "src/paperclip/**/*.spec.tsx"
  ]
}
