{
  "name": "oneearning",
  "version": "0.1.0",
  "private": true,
  "description": "OneEarning — Paperclip 桌面端封装（内嵌 Paperclip UI）",
  "main": "dist-electron/main/index.js",
  "author": "OneEarning",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "pnpm": {
    "supportedArchitectures": {
      "os": ["current"],
      "cpu": ["x64", "arm64"]
    },
    "overrides": {
      "@paperclipai/shared": "file:vendor/paperclip-shared",
      "@paperclipai/adapter-utils": "file:vendor/paperclip-adapter-utils",
      "@paperclipai/adapter-acpx-local": "file:vendor/adapter-acpx-local",
      "@paperclipai/adapter-claude-local": "file:vendor/adapter-claude-local",
      "@paperclipai/adapter-codex-local": "file:vendor/adapter-codex-local",
      "@paperclipai/adapter-cursor-local": "file:vendor/adapter-cursor-local",
      "@paperclipai/adapter-gemini-local": "file:vendor/adapter-gemini-local",
      "@paperclipai/adapter-openclaw-gateway": "file:vendor/adapter-openclaw-gateway",
      "@paperclipai/adapter-opencode-local": "file:vendor/adapter-opencode-local",
      "@paperclipai/adapter-pi-local": "file:vendor/adapter-pi-local"
    }
  },
  "scripts": {
    "dev": "vite",
    "build:vite": "vite build",
    "bundle:paperclip": "zx scripts/prepare-server-bundle.mjs",
    "bundle:postgres": "zx scripts/prepare-postgres.mjs",
    "package": "pnpm run build:vite && pnpm run bundle:paperclip && pnpm run bundle:postgres",
    "build": "pnpm run package && electron-builder",
    "build:win": "pnpm run package && electron-builder --win --publish never",
    "build:mac": "pnpm run package && electron-builder --mac --publish never",
    "build:linux": "pnpm run package && electron-builder --linux --publish never",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "build:vendor": "node scripts/build-vendor.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "prep:node:win": "zx scripts/download-bundled-node.mjs --platform=win"
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.23",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/link": "0.35.0",
    "@mdxeditor/editor": "^3.52.4",
    "@paperclipai/adapter-acpx-local": "file:vendor/adapter-acpx-local",
    "@paperclipai/adapter-claude-local": "file:vendor/adapter-claude-local",
    "@paperclipai/adapter-codex-local": "file:vendor/adapter-codex-local",
    "@paperclipai/adapter-cursor-local": "file:vendor/adapter-cursor-local",
    "@paperclipai/adapter-gemini-local": "file:vendor/adapter-gemini-local",
    "@paperclipai/adapter-openclaw-gateway": "file:vendor/adapter-openclaw-gateway",
    "@paperclipai/adapter-opencode-local": "file:vendor/adapter-opencode-local",
    "@paperclipai/adapter-pi-local": "file:vendor/adapter-pi-local",
    "@paperclipai/adapter-utils": "file:vendor/paperclip-adapter-utils",
    "@paperclipai/shared": "file:vendor/paperclip-shared",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "get-port": "^7.1.0",
    "i18next": "^24.2.0",
    "hermes-paperclip-adapter": "^0.2.0",
    "lexical": "0.35.0",
    "lucide-react": "^0.574.0",
    "mermaid": "^11.12.0",
    "paperclipai": "0.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.5",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.29.0",
    "zx": "^8.3.0"
  }
}
